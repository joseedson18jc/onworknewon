# Copy to .env.local for dev, or set each in your Vercel project's Environment
# Variables panel. In DEMO MODE (all missing) the app runs with an in-memory
# user store and canned provider responses so links still work.

# --- Session (required in production) ---
# Generate: openssl rand -base64 48
AUTH_SECRET=

# --- Vercel KV / Upstash Redis (required for real auth + rate-limits + audit) ---
# Create a KV store in the Vercel dashboard; the below are auto-populated.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Provider proxies (required for live AI / voice / enrichment) ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
SURFE_API_KEY=

# --- Email (optional — forgot-password uses Resend when set; returns demoLink otherwise) ---
RESEND_API_KEY=
